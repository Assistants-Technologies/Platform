	reverse_proxy kratos:4433 {
		header_up X-Forwarded-Proto https
		header_up Host {host}
	}
}

http://oauth.assts.site {
	reverse_proxy hydra:4444 {
		header_up X-Forwarded-Proto https
		header_up Host {host}
	}
}

:80 {
	redir https://{host}{uri} permanent
}